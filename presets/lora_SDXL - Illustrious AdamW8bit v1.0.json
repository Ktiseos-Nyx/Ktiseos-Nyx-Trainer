{
  "name": "Illustrious-XL - AdamW8bit",
  "description": "Illustrious-XL LoRA training using AdamW8bit. Separate TE and UNet LRs, noise offset 0.1, min_snr 5. No clip skip. Derived from real community training runs on Illustrious-XL v0.1.",
  "model_type": "SDXL",
  "is_builtin": true,
  "source": "community",
  "base_model": "illustriousXL_v01.safetensors (or similar Illustrious/NAI-derived SDXL model)",

  "project_name": "my_illustrious_lora",
  "pretrained_model_name_or_path": "",
  "vae_path": "",
  "train_data_dir": "",
  "output_dir": "output",
  "output_name": "my_illustrious_lora",

  "resolution": 1024,
  "num_repeats": 5,
  "max_train_epochs": 15,
  "max_train_steps": 0,
  "train_batch_size": 2,
  "seed": 42,

  "flip_aug": false,
  "random_crop": false,
  "color_aug": false,
  "shuffle_caption": true,

  "unet_lr": 0.0005,
  "text_encoder_lr": 0.00005,
  "lr_scheduler": "cosine",
  "lr_scheduler_number": 1,
  "lr_warmup_ratio": 0,
  "lr_warmup_steps": 0,
  "lr_power": 1,

  "lora_type": "LoRA",
  "network_dim": 32,
  "network_alpha": 16,
  "conv_dim": 0,
  "conv_alpha": 0,
  "network_dropout": 0,
  "dim_from_weights": false,
  "factor": -1,
  "train_norm": false,
  "rank_dropout": 0,
  "module_dropout": 0,

  "optimizer_type": "AdamW8bit",
  "optimizer_args": "weight_decay=0.0001",
  "gradient_accumulation_steps": 1,
  "max_grad_norm": 1,

  "keep_tokens": 0,
  "clip_skip": 1,
  "max_token_length": 225,
  "caption_dropout_rate": 0,
  "caption_tag_dropout_rate": 0,
  "caption_dropout_every_n_epochs": 0,
  "keep_tokens_separator": ",",
  "secondary_separator": ";",
  "enable_wildcard": false,
  "weighted_captions": false,

  "enable_bucket": true,
  "min_bucket_reso": 256,
  "max_bucket_reso": 2048,
  "bucket_reso_steps": 64,
  "bucket_no_upscale": true,

  "mixed_precision": "bf16",
  "save_precision": "bf16",
  "full_fp16": false,
  "full_bf16": false,
  "fp8_base": false,

  "cache_latents": true,
  "cache_latents_to_disk": false,
  "cache_text_encoder_outputs": false,
  "cache_text_encoder_outputs_to_disk": false,
  "no_half_vae": true,

  "save_model_as": "safetensors",
  "save_every_n_epochs": 1,
  "save_every_n_steps": 0,
  "save_last_n_epochs": 0,
  "save_last_n_epochs_state": 0,
  "save_state": false,
  "save_state_on_train_end": false,
  "resume_from_state": "",

  "logging_dir": "",
  "log_with": "",
  "log_prefix": "",
  "log_tracker_name": "",
  "log_tracker_config": "",
  "wandb_run_name": "",

  "sample_every_n_epochs": 0,
  "sample_every_n_steps": 0,
  "sample_prompts": "",
  "sample_sampler": "euler_a",

  "min_snr_gamma": 5,
  "scale_v_pred_loss_like_noise_pred": false,
  "v_pred_like_loss": 0,
  "debiased_estimation_loss": false,
  "noise_offset": 0.1,
  "adaptive_noise_scale": 0,
  "ip_noise_gamma": 0,
  "ip_noise_gamma_random_strength": false,
  "multires_noise_iterations": 0,
  "multires_noise_discount": 0.3,

  "lowram": false,
  "max_data_loader_n_workers": 8,
  "persistent_data_loader_workers": true,
  "vae_batch_size": 1,
  "min_timestep": 0,
  "max_timestep": 1000,

  "gradient_checkpointing": true,
  "v_parameterization": false,
  "zero_terminal_snr": false
}
