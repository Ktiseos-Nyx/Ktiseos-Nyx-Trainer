{
  "name": "adafactor",
  "description": "SD1.5 training preset with AdaFactor optimizer in adaptive LR mode (scale_parameter=True relative_step=True warmup_init=True). Pairs with adafactor lr_scheduler.",
  "model_type": "SD1.5",
  "is_builtin": true,
  "source": "bmaltais/kohya_ss",

  "resolution": 512,
  "num_repeats": 10,
  "max_train_epochs": 2,
  "max_train_steps": 0,
  "train_batch_size": 1,
  "seed": 1234,

  "flip_aug": false,
  "random_crop": false,
  "color_aug": false,
  "shuffle_caption": true,

  "unet_lr": 0.000001,
  "text_encoder_lr": 0.000001,
  "lr_scheduler": "adafactor",
  "lr_scheduler_number": 0,
  "lr_warmup_steps": 0,
  "lr_warmup_ratio": 0,
  "lr_power": 1,

  "optimizer_type": "AdaFactor",
  "optimizer_args": "scale_parameter=True relative_step=True warmup_init=True",
  "weight_decay": 0.01,
  "gradient_accumulation_steps": 1,
  "max_grad_norm": 1.0,

  "clip_skip": 1,
  "max_token_length": 150,
  "keep_tokens": 1,
  "caption_dropout_rate": 0.1,
  "caption_tag_dropout_rate": 0,
  "caption_dropout_every_n_epochs": 0,
  "caption_extension": ".txt",
  "keep_tokens_separator": ",",
  "secondary_separator": ";",
  "enable_wildcard": false,
  "weighted_captions": false,

  "enable_bucket": true,
  "min_bucket_reso": 256,
  "max_bucket_reso": 1024,
  "bucket_no_upscale": true,

  "mixed_precision": "bf16",
  "save_precision": "fp16",
  "full_fp16": false,
  "gradient_checkpointing": false,
  "cache_latents": true,
  "cache_latents_to_disk": false,
  "cache_text_encoder_outputs": false,

  "save_every_n_epochs": 1,
  "save_every_n_steps": 0,

  "max_data_loader_n_workers": 0,
  "persistent_data_loader_workers": false,

  "v2": false,
  "v_parameterization": false,

  "noise_offset": 0
}
