  "save_every_n_epochs": 1,
  "train_batch_size": 1,
  "mixed_precision": "bf16",
  "noise_offset": 0.1,
  "multires_noise_iterations": 6,
  "multires_noise_discount": 0.3,
  "max_token_length": 225,
  "shuffle_caption": true
