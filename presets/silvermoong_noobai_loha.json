{
  "is_builtin": true,
  "name": "silvermoong's LoHa (NoobAI v-pred)",
  "description": "Published Yoneyama Mai style LoRA by silvermoong. NoobAI v-prediction base, LoHa via LyCORIS, Prodigy at LR=1, massive effective batch (24x12=288). Pick checkpoint around epoch 115.",
  "model_type": "SDXL",
  "lora_type": "LoHa",
  "network_module": "lycoris.kohya",
  "resolution": 1024,
  "network_dim": 8,
  "network_alpha": 8,
  "unet_lr": 1,
  "text_encoder_lr": 1,
  "lr_scheduler": "constant",
  "optimizer_type": "Prodigy",
  "optimizer_args": "decouple=True weight_decay=0.01 use_bias_correction=True d_coef=2.0",
  "max_train_epochs": 200,
  "save_every_n_epochs": 5,
  "train_batch_size": 24,
  "gradient_accumulation_steps": 12,
  "mixed_precision": "bf16",
  "v_parameterization": true,
  "zero_terminal_snr": true,
  "scale_v_pred_loss_like_noise_pred": true
}