{
  "is_builtin": true,
  "name": "Chroma Style (Experimental)",
  "description": "Chroma LoRA style training — very low dim/alpha ratio, fp8 base, frozen text encoder. Uses lora_flux network.",
  "model_type": "Chroma",
  "network_module": "networks.lora_flux",
  "resolution": 1024,
  "network_dim": 2,
  "network_alpha": 16,
  "unet_lr": 0.0005,
  "text_encoder_lr": 0,
  "lr_scheduler": "cosine_with_restarts",
  "optimizer_type": "AdamW8bit",
  "optimizer_args": "weight_decay=0.01 eps=1e-08",
  "max_train_epochs": 20,
  "save_every_n_epochs": 1,
  "train_batch_size": 2,
  "fp8_base": true,
  "mixed_precision": "bf16",
  "noise_offset": 0.1,
  "multires_noise_iterations": 6,
  "multires_noise_discount": 0.3,
  "min_snr_gamma": 5,
  "min_snr_gamma_enabled": true,
  "timestep_sampling": "sigmoid",
  "sigmoid_scale": 1,
  "discrete_flow_shift": 3,
  "guidance_scale": 0,
  "apply_t5_attn_mask": true
}